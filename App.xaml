<Application x:Class="Magazyn_WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Magazyn_WPF"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <System:Double x:Key="BaseFontSize">14</System:Double>
        <System:Double x:Key="HeaderFontSize">24</System:Double>
        <System:Double x:Key="SubHeaderFontSize">20</System:Double>
        
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource BaseFontSize}"/>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="{StaticResource BaseFontSize}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="MinHeight" Value="35"/>
        </Style>
        
        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="{StaticResource BaseFontSize}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="MinHeight" Value="35"/>
        </Style>
        
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="{StaticResource BaseFontSize}"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Application.Resources>
</Application>
