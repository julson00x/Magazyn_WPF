<Window x:Class="Magazyn_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Magazyn_WPF"
        xmlns:views="clr-namespace:Magazyn_WPF.Views"
        mc:Ignorable="d"
        Title="Magazyn Produktów" WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Grid Background="#f5f5f5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Background="#1a1a1a" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,15,20,15">
            <TextBlock Text="Magazyn Produktów" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>

        <views:ProductListView Grid.Row="1" x:Name="ProductListView"/>
    </Grid>
</Window>
