<Window x:Class="Magazyn_WPF.Views.ProductFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Formularz Produktu" Height="550" Width="500" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Background="White">
        <Grid Margin="30" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Formularz Produktu" Grid.Row="0" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Nazwa:" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="NazwaTextBox" Grid.Column="1"/>
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Kategoria:" Grid.Column="0" VerticalAlignment="Center"/>
                <ComboBox x:Name="KategoriaComboBox" Grid.Column="1">
                    <ComboBoxItem>Elektronika</ComboBoxItem>
                    <ComboBoxItem>Narzędzia</ComboBoxItem>
                    <ComboBoxItem>Meble</ComboBoxItem>
                    <ComboBoxItem>Materiały budowlane</ComboBoxItem>
                    <ComboBoxItem>Inne</ComboBoxItem>
                </ComboBox>
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ilość:" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="IlośćTextBox" Grid.Column="1"/>
            </Grid>

            <Grid Grid.Row="4" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Jednostka:" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="JednostkaTextBox" Grid.Column="1"/>
            </Grid>

            <Grid Grid.Row="5" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Lokalizacja:" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="LokalizacjaTextBox" Grid.Column="1"/>
            </Grid>

            <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="Zapisz" Margin="0,0,10,0" Background="#4CAF50" Click="SaveButton_Click"/>
                <Button Content="Anuluj" Background="#9E9E9E" Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
